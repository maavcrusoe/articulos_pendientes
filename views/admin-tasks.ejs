<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin — Tareas programadas</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .task-list { display: flex; flex-direction: column; gap: 1rem; }
        .task-card {
            border: 1px solid var(--border, #e5e7eb);
            border-radius: 8px;
            padding: 1.25rem 1.5rem;
            display: flex;
            align-items: flex-start;
            gap: 1.5rem;
            background: var(--surface, #fff);
        }
        .task-card-info { flex: 1; min-width: 0; }
        .task-card-info h3 { margin: 0 0 0.25rem; font-size: 1rem; }
        .task-card-info p  { margin: 0 0 0.5rem; font-size: 0.875rem; color: var(--text-muted, #6b7280); }
        .task-meta { display: flex; flex-wrap: wrap; gap: 0.5rem 1.25rem; font-size: 0.8rem; color: var(--text-muted, #6b7280); margin-top: 0.5rem; }
        .task-meta strong { color: var(--text, #111); }
        .task-status-ok    { color: #16a34a; font-weight: 600; }
        .task-status-error { color: #dc2626; font-weight: 600; }
        .task-status-running { color: #f59e0b; font-weight: 600; }
        .task-card-action { flex-shrink: 0; }
        .task-card-shell { display: flex; flex-direction: column; gap: 1rem; width: 100%; }
        .task-result-panel {
            border-top: 1px solid var(--border, #e5e7eb);
            padding-top: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.9rem;
        }
        .task-result-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 0.75rem;
        }
        .task-result-stat {
            padding: 0.9rem 1rem;
            border-radius: 10px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }
        .task-result-stat strong { display: block; font-size: 1.15rem; color: #0f172a; }
        .task-result-stat span { font-size: 0.78rem; color: #64748b; }
        .task-inline-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
        .duplicate-groups-form { display: flex; flex-direction: column; gap: 0.85rem; }
        .duplicate-group-list { display: flex; flex-direction: column; gap: 0.75rem; max-height: 420px; overflow: auto; }
        .duplicate-group {
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 0.9rem 1rem;
            background: #fff;
        }
        .duplicate-group-header { display: flex; gap: 0.75rem; align-items: flex-start; }
        .duplicate-group-header input { margin-top: 0.25rem; }
        .duplicate-group-body { display: flex; flex-direction: column; gap: 0.35rem; min-width: 0; }
        .duplicate-url { font-weight: 700; color: #1d4ed8; word-break: break-all; }
        .duplicate-note { color: #64748b; font-size: 0.85rem; }
        .duplicate-item-list { margin: 0; padding-left: 1.1rem; color: #475569; font-size: 0.88rem; }
        .task-json-preview {
            margin: 0;
            padding: 1rem;
            border-radius: 12px;
            background: #0f172a;
            color: #e2e8f0;
            overflow: auto;
            font-size: 0.82rem;
        }
        @media (max-width: 600px) {
            .task-card { flex-direction: column; }
        }
        /* ===== New dynamic task form ===== */
        .new-task-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem 1.5rem;
        }
        .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
        .form-group--full { grid-column: 1 / -1; }
        .form-group label { font-size: 0.875rem; font-weight: 600; color: var(--text, #111); }
        .form-group .required { color: #dc2626; }
        .label-hint { font-weight: 400; color: var(--text-muted, #6b7280); font-size: 0.8rem; }
        .form-group input, .form-group textarea {
            padding: 0.5rem 0.75rem;
            border: 1px solid var(--border, #e5e7eb);
            border-radius: 6px;
            font-size: 0.875rem;
            font-family: inherit;
            background: #fff;
            transition: border-color .15s;
        }
        .form-group input:focus, .form-group textarea:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 2px rgba(99,102,241,.15);
        }
        .form-group textarea { resize: vertical; font-family: 'Courier New', monospace; font-size: 0.82rem; }
        .form-group small { font-size: 0.78rem; color: var(--text-muted, #6b7280); }
        .cron-presets { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin-top: 0.5rem; }
        .cron-presets-label { font-size: 0.8rem; color: var(--text-muted, #6b7280); }
        .cron-preset-btn {
            background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 20px;
            padding: 0.25rem 0.75rem; font-size: 0.8rem; cursor: pointer; transition: background .15s;
        }
        .cron-preset-btn:hover { background: #e0e7ff; border-color: #6366f1; }
        .form-actions { display: flex; gap: 0.75rem; margin-top: 1.25rem; }
        @media (max-width: 600px) {
            .new-task-grid { grid-template-columns: 1fr; }
            .form-group--full { grid-column: 1; }
        }
    </style>
</head>
<body>
    <div class="container admin-shell" data-admin-page="tasks">
        <%- include('partials/admin-navbar', { currentAdminSection: 'tasks', user: user }) %>
        <div class="admin-header">
            <div>
                <span class="admin-eyebrow">Panel privado</span>
                <h1>Tareas programadas</h1>
                <p class="admin-subtitle">Gestiona las tareas automáticas del sistema. Puedes ejecutarlas manualmente en cualquier momento.</p>
            </div>
        </div>

        <% if (error) { %>
            <div class="admin-alert admin-alert-error"><%= error %></div>
        <% } %>
        <% if (success) { %>
            <div class="admin-alert admin-alert-success"><%= success %></div>
        <% } %>

        <div class="admin-stats-grid">
            <div class="admin-stat-card">
                <span class="admin-stat-value"><%= tasks.length %></span>
                <span class="admin-stat-label">Tareas registradas</span>
            </div>
            <div class="admin-stat-card">
                <span class="admin-stat-value"><%= tasks.filter(t => t.lastStatus === 'ok').length %></span>
                <span class="admin-stat-label">Ejecutadas OK</span>
            </div>
        </div>

        <div class="admin-panel">
            <div class="admin-panel-header">
                <h2>Tareas activas</h2>
                <p>Todas las tareas envían su resultado por Telegram si <code>TELEGRAM_TOKEN</code> y <code>TELEGRAM_CHAT_ID</code> están configurados en el entorno.</p>
            </div>

            <div class="task-list">
                <% tasks.forEach((task) => { %>
                    <div class="task-card">
                        <div class="task-card-shell">
                            <div style="display:flex; gap:1.5rem; align-items:flex-start; justify-content:space-between; flex-wrap:wrap;">
                                <div class="task-card-info">
                                    <h3><%= task.name %></h3>
                                    <p><%= task.description %></p>
                                    <div class="task-meta">
                                        <span>⏰ <strong><%= task.scheduleLabel %></strong> (<code><%= task.schedule %></code>, <%= task.timezone %>)</span>
                                        <% if (task.lastRun) { %>
                                            <span>Última ejecución: <strong><%= new Date(task.lastRun).toLocaleString('es-ES') %></strong></span>
                                            <% if (task.lastStatus === 'ok') { %>
                                                <span class="task-status-ok">✅ <%= task.lastMessage %></span>
                                            <% } else if (task.lastStatus === 'error') { %>
                                                <span class="task-status-error">❌ <%= task.lastMessage %></span>
                                            <% } else if (task.lastStatus === 'running') { %>
                                                <span class="task-status-running">⏳ Ejecutando...</span>
                                            <% } %>
                                        <% } else { %>
                                            <span>Aún no ejecutada en esta sesión.</span>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="task-card-action">
                                    <div style="display:flex; flex-direction:column; gap:0.5rem; align-items:flex-end;">
                                    <form method="POST" action="/admin/tasks/<%= task.id %>/run"
                                          onsubmit="return confirm('¿Ejecutar ahora la tarea «<%= task.name %>»?');">
                                        <button type="submit" class="admin-btn btn-save">Ejecutar ahora</button>
                                    </form>
                                    <% if (task.dynamic) { %>
                                        <form method="POST" action="/admin/tasks/<%= task.id %>/delete-dynamic"
                                              onsubmit="return confirm('¿Eliminar la tarea «<%= task.name %>»? Esta acción no se puede deshacer.');">
                                            <button type="submit" class="admin-btn btn-danger" style="font-size:0.8rem; padding:0.35rem 0.75rem;">Eliminar</button>
                                        </form>
                                    <% } %>
                                    </div>
                                </div>
                            </div>

                            <% if (task.lastResult) { %>
                                <div class="task-result-panel">
                                    <div class="admin-panel-header" style="margin-bottom:0;">
                                        <h2 style="font-size:1rem; margin:0;">Resultado de la última ejecución</h2>
                                    </div>

                                    <% if (task.id === 'duplicateUrls') { %>
                                        <div class="task-result-grid">
                                            <div class="task-result-stat"><strong><%= task.lastResult.duplicateGroups || 0 %></strong><span>URLs duplicadas</span></div>
                                            <div class="task-result-stat"><strong><%= task.lastResult.removableItems || 0 %></strong><span>Elementos eliminables</span></div>
                                        </div>

                                        <% if (task.lastResult.groups && task.lastResult.groups.length) { %>
                                            <form method="POST" action="/admin/tasks/duplicateUrls/delete" class="duplicate-groups-form" onsubmit="return confirm('Se eliminarán las copias más nuevas de las URLs seleccionadas y se conservará siempre la más antigua.');">
                                                <div class="duplicate-note">Selecciona una o varias URLs. Se conservará el primer artículo guardado y se eliminarán todas las copias más nuevas de cada grupo.</div>
                                                <div class="duplicate-group-list">
                                                    <% task.lastResult.groups.forEach((group) => { %>
                                                        <label class="duplicate-group">
                                                            <div class="duplicate-group-header">
                                                                <input type="checkbox" name="urls" value="<%= group.url %>">
                                                                <div class="duplicate-group-body">
                                                                    <span class="duplicate-url"><%= group.url %></span>
                                                                    <span class="duplicate-note">Aparece <strong><%= group.count %></strong> veces. Se mantiene: <strong><%= group.keepItem?.title || 'Sin título' %></strong>.</span>
                                                                    <% if (group.deleteItems && group.deleteItems.length) { %>
                                                                        <ol class="duplicate-item-list">
                                                                            <% group.deleteItems.forEach((item) => { %>
                                                                                <li><%= item.title || 'Sin título' %></li>
                                                                            <% }); %>
                                                                        </ol>
                                                                    <% } %>
                                                                </div>
                                                            </div>
                                                        </label>
                                                    <% }); %>
                                                </div>
                                                <div class="task-inline-actions">
                                                    <button type="submit" class="admin-btn btn-danger">Eliminar duplicados seleccionados</button>
                                                </div>
                                            </form>
                                        <% } else { %>
                                            <div class="empty-state">No se detectaron duplicados en la última ejecución.</div>
                                        <% } %>
                                    <% } else if (task.id === 'untaggedLinks') { %>
                                        <div class="task-result-grid">
                                            <div class="task-result-stat"><strong><%= task.lastResult.count || 0 %></strong><span>Links sin etiqueta</span></div>
                                        </div>
                                        <div class="task-inline-actions">
                                            <a href="<%= task.lastResult.filterUrl || '/links-vistos?filter=untagged' %>" class="admin-btn btn-ghost">Ver links sin etiqueta</a>
                                        </div>
                                    <% } else if (task.id === 'scrapeAnalyze') { %>
                                        <div class="task-result-grid">
                                            <div class="task-result-stat"><strong><%= task.lastResult.total || 0 %></strong><span>Total procesados</span></div>
                                            <div class="task-result-stat"><strong><%= task.lastResult.analyzed || 0 %></strong><span>Analizados</span></div>
                                            <div class="task-result-stat"><strong><%= task.lastResult.errors || 0 %></strong><span>Errores</span></div>
                                        </div>
                                    <% } else if (task.id === 'tagMergeProposals') { %>
                                        <div class="task-result-grid">
                                            <div class="task-result-stat"><strong><%= task.lastResult.newProposals || 0 %></strong><span>Nuevas propuestas</span></div>
                                            <div class="task-result-stat"><strong><%= task.lastResult.totalPending || 0 %></strong><span>Pendientes de revisión</span></div>
                                        </div>
                                        <div class="task-inline-actions">
                                            <a href="/admin/tag-merges" class="admin-btn btn-ghost">Revisar propuestas</a>
                                        </div>
                                    <% } else { %>
                                        <pre class="task-json-preview"><%= JSON.stringify(task.lastResult, null, 2) %></pre>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>

        <!-- ===== NUEVA TAREA DINÁMICA ===== -->
        <div class="admin-panel" style="margin-top:2rem;" id="new-task-panel">
            <div class="admin-panel-header">
                <h2>Crear nueva tarea automática</h2>
                <p>Define una tarea personalizada que se ejecutará según el horario cron indicado. El código JavaScript tiene acceso a los módulos de Node.js del servidor.</p>
            </div>

            <form method="POST" action="/admin/tasks/new" class="new-task-form" id="newTaskForm">
                <div class="new-task-grid">
                    <!-- ID -->
                    <div class="form-group">
                        <label for="task-id">ID único <span class="required">*</span></label>
                        <input type="text" id="task-id" name="id" required
                               pattern="[a-zA-Z][a-zA-Z0-9_\-]{1,39}"
                               placeholder="miTareaEjemplo"
                               title="Empieza por letra; sólo letras, números, _ y -">
                        <small>Identificador interno (sin espacios). Ej: <code>weeklyStats</code></small>
                    </div>

                    <!-- Nombre -->
                    <div class="form-group">
                        <label for="task-name">Nombre visible <span class="required">*</span></label>
                        <input type="text" id="task-name" name="name" required placeholder="Estadísticas semanales">
                    </div>

                    <!-- Descripción -->
                    <div class="form-group form-group--full">
                        <label for="task-desc">Descripción</label>
                        <input type="text" id="task-desc" name="description" placeholder="Qué hace esta tarea y qué reporta">
                    </div>

                    <!-- Expresión cron -->
                    <div class="form-group">
                        <label for="task-schedule">Expresión cron <span class="required">*</span></label>
                        <input type="text" id="task-schedule" name="schedule" required placeholder="0 9 * * 1"
                               pattern="(\S+\s){4}\S+" title="5 campos cron: minuto hora día-mes mes día-semana">
                        <small id="cron-hint">Ej: <code>0 9 * * 1</code> = lunes a las 09:00</small>
                    </div>

                    <!-- Label legible -->
                    <div class="form-group">
                        <label for="task-label">Etiqueta horario</label>
                        <input type="text" id="task-label" name="scheduleLabel" placeholder="Lunes a las 09:00">
                        <small>Texto que se mostrará en el panel (opcional)</small>
                    </div>

                    <!-- Zona horaria -->
                    <div class="form-group">
                        <label for="task-tz">Zona horaria</label>
                        <input type="text" id="task-tz" name="timezone" value="Europe/Madrid" placeholder="Europe/Madrid">
                    </div>

                    <!-- Script body -->
                    <div class="form-group form-group--full">
                        <label for="task-script">Código JavaScript <span class="required">*</span>
                            <span class="label-hint">— cuerpo de <code>async function run() { … }</code></span>
                        </label>
                        <textarea id="task-script" name="scriptBody" rows="12" required
                                  placeholder="// Ejemplo: enviar un log de cuántos artículos hay
const { getCollection } = require('../db');
const collection = getCollection();
const total = await collection.countDocuments({});
console.log('\u2705 Total artículos:', total);
return { total };"></textarea>
                        <small>Usa <code>require('../db')</code>, <code>require('../logger')</code>, etc. El valor retornado se muestra en el panel como resultado.</small>
                    </div>
                </div>

                <!-- Atajos de cron -->
                <div class="cron-presets">
                    <span class="cron-presets-label">Atajos:</span>
                    <button type="button" class="cron-preset-btn" data-cron="0 9 * * *" data-label="Diario a las 09:00">Diario 09:00</button>
                    <button type="button" class="cron-preset-btn" data-cron="0 9 * * 1" data-label="Lunes a las 09:00">Lunes 09:00</button>
                    <button type="button" class="cron-preset-btn" data-cron="30 10 * * 0" data-label="Domingos a las 10:30">Domingo 10:30</button>
                    <button type="button" class="cron-preset-btn" data-cron="0 */6 * * *" data-label="Cada 6 horas">Cada 6h</button>
                    <button type="button" class="cron-preset-btn" data-cron="0 8 1 * *" data-label="El 1 de cada mes a las 08:00">Mensual</button>
                </div>

                <div class="form-actions">
                    <button type="submit" class="admin-btn btn-save">Guardar y activar tarea</button>
                    <button type="button" class="admin-btn btn-ghost" onclick="document.getElementById('newTaskForm').reset()">Limpiar</button>
                </div>
            </form>
        </div>
        <!-- /NUEVA TAREA DINÁMICA -->

    </div>
    <script src="/script.js"></script>
    <script>
        // Cron preset buttons
        document.querySelectorAll('.cron-preset-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                document.getElementById('task-schedule').value = btn.dataset.cron;
                document.getElementById('task-label').value = btn.dataset.label;
            });
        });
    </script>
</body>
</html>
